{
  "name": "vite-plugin-caddy-multiple-tls-root",
  "version": "0.0.1",
  "private": true,
  "homepage": "https://github.com/vampaz/vite-plugin-caddy-multiple-tls/#readme",
  "bugs": {
    "url": "https://github.com/vampaz/vite-plugin-caddy-multiple-tls/issues"
  },
  "license": "MIT",
  "author": "vampaz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vampaz/vite-plugin-caddy-multiple-tls.git"
  },
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "type": "module",
  "scripts": {
    "start": "npm run start --workspaces --if-present",
    "build": "npm run build --workspace packages/plugin",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "npm run lint && npm run format:check",
    "check:fix": "npm run format && npm run lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
